# Switchboard deploy stack — copy to `.env` and edit, then:
#   docker compose --env-file .env -f deploy/docker-compose.yml up -d --build
#
# The stack comes up with ONLY the two "set before first boot" values below.
# Everything else gates a single real-mode feature (see HUMAN_TODO.md); leave a
# variable unset and that feature stays mocked/disabled — the stack still boots.
# Full matrix + notes: deploy/README.md.

# ── Required before first boot ───────────────────────────────────────────────
POSTGRES_PASSWORD=change-me-before-first-boot
# >=32 chars in production (the api refuses to start otherwise). Signs sessions
# AND derives the OAuth-token encryption key — rotating forces mailbox re-auth.
#   generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# The API rejects the committed placeholder below; replace it before boot.
SESSION_SECRET=change-me-32-chars-minimum-000000

# ── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
# 1 = every external provider mocked, zero accounts needed. 0 = real mode.
MOCK_MODE=1
PORT=3000
WEB_HTTP_PORT=8080
POSTGRES_USER=switchboard
POSTGRES_DB=switchboard
# DATABASE_URL / REDIS_URL are auto-derived to the in-cluster services.
# Set them ONLY to point at an external Postgres/Redis.
#DATABASE_URL=
#REDIS_URL=

# Signs one-click unsubscribe tokens (I-SEND-5). Generate like SESSION_SECRET.
LIST_UNSUBSCRIBE_SECRET=

# ── SSO (Phase 5) — company IdP, OIDC. Dev-login stub covers until set ───────
# Groups: `sales-crm-users` (login) / `sales-crm-admins` (admin).
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# Absolute origin the OIDC callback returns to (the web front door).
WEB_ORIGIN=http://localhost:8080
#
# To prove real SSO with NO company account, use the bundled Keycloak
# (`--profile keycloak`, see deploy/KEYCLOAK.md) and set:
#   MOCK_MODE=0
#   OIDC_ISSUER=http://localhost:8081/realms/switchboard
#   OIDC_CLIENT_ID=switchboard
#   OIDC_CLIENT_SECRET=switchboard-dev-secret
# Keycloak admin console creds (change if you expose it):
#KEYCLOAK_ADMIN=admin
#KEYCLOAK_ADMIN_PASSWORD=admin

# ── Real-mode providers (each blocks only its own feature) ───────────────────
# Gmail two-way sync
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GMAIL_SENDER_ADDRESS=
GMAIL_PUSH_AUDIENCE=
GMAIL_PUSH_SERVICE_ACCOUNT_EMAIL=
# Haiku 4.5 summaries / drafting / NL→Smart View
ANTHROPIC_API_KEY=
# Calling + SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_TWIML_APP_SID=
TWILIO_PHONE_NUMBER=
# Call transcription (optional)
DEEPGRAM_API_KEY=
# Public HTTPS origin the proxy forwards to /wh/* (Twilio signs the full URL)
PUBLIC_WEBHOOK_URL=

# ── Optional: self-hosted error tracking (profile `glitchtip`) ───────────────
# Required ONLY when you enable that profile; GlitchTip refuses to boot without it.
GLITCHTIP_SECRET_KEY=
GLITCHTIP_DB=glitchtip
GLITCHTIP_DOMAIN=http://localhost:8000
GLITCHTIP_FROM_EMAIL=glitchtip@localhost

# ── Backups ─────────────────────────────────────────────────────────────────
#BACKUP_DIR=
#BACKUP_RETENTION=14
