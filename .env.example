# Switchboard environment — copy to .env and fill in.
# The build runs fully under MOCK_MODE=1 with none of the real keys below.
# Real-mode keys correspond to HUMAN_TODO.md items; each blocks only its named feature.

# --- Core runtime ---
MOCK_MODE=1
NODE_ENV=development
PORT=3000
DATABASE_URL=postgres://switchboard:switchboard@localhost:5432/switchboard
REDIS_URL=redis://localhost:6379
SESSION_SECRET=change-me-in-production

# --- AI (Haiku 4.5): summaries / drafting / NL→SmartView (Phase 3–4 real mode) ---
ANTHROPIC_API_KEY=

# --- Gmail two-way sync (Phase 2 real mode) ---
# Redirect URI (dev): http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Company IdP OIDC / SSO (Phase 5; dev-login stub covers until then) ---
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# --- Twilio calling + SMS (Phase 3 real mode) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_PHONE_NUMBER=

# --- Deepgram call transcription (optional, deferrable) ---
DEEPGRAM_API_KEY=

# --- Public webhook tunnel URL for Twilio + Gmail push callbacks (real mode dev) ---
PUBLIC_WEBHOOK_URL=
