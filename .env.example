# Switchboard environment — copy to .env and fill in. PLACEHOLDERS ONLY in this
# file; never commit real secrets (.env is gitignored).
#
# The whole stack brings up under MOCK_MODE=1 with ZERO external accounts: set
# POSTGRES_PASSWORD + SESSION_SECRET, leave the rest, and `docker compose up`
# works (providers are mocked). Flip MOCK_MODE=0 and fill a credential group to
# turn on that real integration — each group blocks only its named feature
# (mirrors HUMAN_TODO.md). Full matrix + which-service/secret table: deploy/README.md.
#
# This .env is read by docker compose (variable substitution) AND passed into the
# api container (env_file). See deploy/docker-compose.yml.

# ============================================================================
# Core runtime                                        [service: api · web(build)]
# ============================================================================
# MOCK_MODE=1 → all providers mocked, no accounts needed. 0 → real integrations.
MOCK_MODE=1
NODE_ENV=production
# API listen port INSIDE the container (the compose network). Not host-published.
PORT=3000
# Host port the web front door (nginx) is published on. Company TLS proxy → here.
WEB_HTTP_PORT=8080

# ============================================================================
# Postgres                                                     [service: postgres]
# ============================================================================
# POSTGRES_* seed the postgres container AND compose-derives DATABASE_URL from
# them. Change the password before first boot. (secret: POSTGRES_PASSWORD)
POSTGRES_USER=switchboard
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=switchboard
# DATABASE_URL is set for the api by compose to the in-cluster postgres. Only set
# it here to point at an EXTERNAL/managed Postgres instead of the bundled one.
# DATABASE_URL=postgres://user:pass@db.internal:5432/switchboard

# ============================================================================
# Redis                                                           [service: redis]
# ============================================================================
# Compose sets the api's REDIS_URL to the in-cluster redis. Override only for an
# external Redis.
# REDIS_URL=redis://redis.internal:6379

# ============================================================================
# App secrets                                                       [service: api]
# ============================================================================
# Signs sessions AND derives the encryption key for stored OAuth tokens
# (TokenCipher). Use a long random value; ROTATING IT invalidates linked-mailbox
# tokens (reps must re-auth). (secret: yes) e.g. `openssl rand -hex 32`
# The API rejects this committed placeholder in production; replace it before boot.
SESSION_SECRET=change-me-to-a-64-char-random-hex-string
# Secret that signs one-click List-Unsubscribe tokens (I-SEND-5). (secret: yes)
LIST_UNSUBSCRIBE_SECRET=change-me-random-hex

# ============================================================================
# Company IdP / SSO (OIDC)                            [service: api · real mode]
# ============================================================================
# Google Workspace default. Create groups `sales-crm-users` and
# `sales-crm-admins` (admin RBAC maps to the latter). Dev-login stub covers until
# this is set. (secret: OIDC_CLIENT_SECRET)
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
WEB_ORIGIN=https://switchboard.example.com

# ============================================================================
# Gmail two-way sync                                  [service: api · real mode]
# ============================================================================
# Redirect URI (prod): https://<app-url>/api/v1/oauth/gmail/callback. (secret: GOOGLE_CLIENT_SECRET)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GMAIL_SENDER_ADDRESS=
GMAIL_PUSH_AUDIENCE=
GMAIL_PUSH_SERVICE_ACCOUNT_EMAIL=

# ============================================================================
# AI — Haiku 4.5 (summaries / drafting / NL->SmartView) [service: api · real]
# ============================================================================
# (secret: yes)
ANTHROPIC_API_KEY=

# ============================================================================
# Twilio calling + SMS                                [service: api · real mode]
# ============================================================================
# (secret: TWILIO_AUTH_TOKEN, TWILIO_API_KEY_SECRET)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_TWIML_APP_SID=
TWILIO_PHONE_NUMBER=

# ============================================================================
# Deepgram call transcription                        [service: api · real mode]
# ============================================================================
# (secret: yes)
DEEPGRAM_API_KEY=

# ============================================================================
# Webhook ingress URL                                 [service: api · real mode]
# ============================================================================
# Public HTTPS URL the company proxy forwards to /wh/* (Twilio + Gmail push).
PUBLIC_WEBHOOK_URL=

# ============================================================================
# GlitchTip error tracking (optional)      [profile: glitchtip — OFF by default]
# ============================================================================
# Enable with `docker compose --profile glitchtip up`. Needs a dedicated DB
# (create it in the bundled postgres or point at an external one). (secret: GLITCHTIP_SECRET_KEY)
GLITCHTIP_SECRET_KEY=
GLITCHTIP_DB=glitchtip
GLITCHTIP_DOMAIN=http://localhost:8000
GLITCHTIP_FROM_EMAIL=glitchtip@localhost

# ============================================================================
# Backups (optional overrides — see deploy/scripts/backup.sh)
# ============================================================================
# BACKUP_DIR=/srv/switchboard/backups
# BACKUP_RETENTION=14
