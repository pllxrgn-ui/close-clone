{
  "name": "switchboard",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.31.0",
  "pnpm": {
    "overrides": {
      "@esbuild-kit/core-utils>esbuild": "0.25.12",
      "fast-uri@3.1.3": "3.1.4",
      "fast-uri@4.1.0": "4.1.1"
    }
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "perf": "node scripts/perf.mjs",
    "fixtures:generate": "pnpm --filter @switchboard/fixtures run generate",
    "test:deploy": "pnpm --dir deploy install --ignore-workspace --frozen-lockfile && pnpm --dir deploy run test"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0"
  }
}
