{
  "name": "@switchboard/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.ts",
    "start": "node src/index.ts",
    "admin": "node --experimental-transform-types src/cli/index.ts",
    "build": "tsc --noEmit",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.2.17",
    "@switchboard/shared": "workspace:*",
    "bullmq": "^5.80.4",
    "drizzle-orm": "^0.38.3",
    "fastify": "^5.2.1",
    "pg": "^8.22.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.30.6",
    "vitest": "^3.0.4"
  }
}
